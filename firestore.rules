rules_version = '2';

// Writes happen ONLY through the `submitDcrV1` Cloud Function (Admin SDK
// bypasses these rules) and through the future admin write functions
// (createCustomerV1, archiveCustomerV1, createTechV1, archiveTechV1).
//
// Reads on the three admin-visible collections are intentionally open so the
// static admin page at /admin.html can fetch them directly via the Firebase
// Web SDK without an auth round-trip. Everything else is default-deny.
//
// ⚠ BEFORE PRODUCTION / PUBLIC ROLLOUT
// ===================================
// Replace `allow read: if true;` with a Firebase Auth + custom-claims gate,
// e.g. `allow read: if request.auth.token.admin == true;` and wire the admin
// page to a sign-in flow. Until then, treat the /admin.html URL as
// "obscure-but-not-secret" and only share it internally.
service cloud.firestore {
  match /databases/{database}/documents {

    // Allowlist-gated admin check used by /supply_requests. Mirrors the
    // ALLOWED_ADMIN_EMAILS array in public/admin.js — keep them in sync. If
    // you add/remove an admin, edit BOTH this list and admin.js, then deploy
    // hosting + firestore:rules together.
    // Why this is the simpler form (and why the previous version blocked
    // legitimate admin writes):
    //   • `request.auth.token != null` is redundant — when request.auth is
    //     truthy, the token map is always present. The old check was noise.
    //   • `request.auth.token.email_verified == true` is the silent-deny
    //     trap: when the `email_verified` claim is missing from the ID
    //     token for any reason, the comparison evaluates false and denies
    //     the whole write. Google sign-in already requires a verified
    //     email at the IdP layer, so this check was paranoid. Dropping it.
    //   • `... .email is string` is a safe type test that returns false
    //     (not throws) for missing or non-string fields — defends against
    //     a degenerate token without the email_verified pitfall.
    //
    // The email allowlist below is the actual security boundary. It MUST
    // stay in sync with ALLOWED_ADMIN_EMAILS in public/admin.js — Google
    // returns normalized lowercase emails, and `.lower()` mirrors what
    // admin.js does client-side.
    // Admin gate. Two-tier model so admins can be added at runtime
    // (via the Admins tab in /admin) without editing source:
    //   1. Hardcoded "root" allowlist — survives Firestore outages,
    //      always works, used to bootstrap.
    //   2. Firestore-backed `admins/{email}` doc with active != false
    //      — lets root admins invite operational admins without a
    //      code deploy. The doc ID is the lowercased email.
    //
    // Adding an admin: write /admins/{email}. Removing: set active:
    // false on the doc (or delete it). Keep this list in sync with
    // ALLOWED_ADMIN_EMAILS in public/admin.js + functions/index.js.
    function isPioneerAdmin() {
      return request.auth != null
        && request.auth.token.email is string
        && (
          request.auth.token.email.lower() in [
            "nick@pioneercomclean.com",
            "april@pioneercomclean.com",
            "kirby@pioneercomclean.com",
            "mgies@pioneercomclean.com"
          ]
          || (
            exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()))
            && get(/databases/$(database)/documents/admins/$(request.auth.token.email.lower())).data.active != false
          )
        );
    }

    // Active-staff gate for FIELD-TECH writes. The auth token carries
    // the email; we look up the matching cleaning_techs/{slug} doc by
    // walking the index doc at active_techs_by_email/{email_lc} which
    // stores { active: bool, slug: string, email: string }. Pure
    // existence check — no extra Firestore reads when this gate fires.
    //
    // An admin always passes regardless of the index.
    //
    // Adding/removing this index is handled automatically by the
    // archive flow in admin.js: on archive, the index doc gets
    // `active: false`; on reactivate, `active: true`. The Firestore
    // rule treats absent doc OR active != true as denied.
    function isActiveCleaningTech() {
      return request.auth != null
        && request.auth.token.email is string
        && exists(/databases/$(database)/documents/active_techs_by_email/$(request.auth.token.email.lower()))
        && get(/databases/$(database)/documents/active_techs_by_email/$(request.auth.token.email.lower())).data.active == true;
    }
    function isActiveStaff() {
      return isPioneerAdmin() || isActiveCleaningTech();
    }

    // Customers + cleaning techs are read-open (public form dropdowns query them
    // anonymously). Writes are gated to the admin allowlist via isPioneerAdmin()
    // so the new edit/archive controls in /admin work, but no anonymous client
    // can mutate. Deletes are denied outright — archive (active=false) is the
    // only way to remove a record from circulation.
    // customers + cleaning_techs are read by the DCR form's dropdowns AND
    // by the tech hub. Both pages now require staff sign-in before they
    // render, so we can tighten read access from "anyone" to "any
    // authenticated Firebase user". Non-staff signed-in users can still
    // technically query these collections via raw SDK calls, but the
    // page-level gate + function-level token verification stop them from
    // doing anything useful with the data.
    match /customers/{id} {
      allow read:   if request.auth != null;
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // customer_secure — admin-only mirror collection that holds the
    // SENSITIVE half of a customer's SOP: alarm codes, door / gate
    // codes, emergency contacts, raw Deputy notes, and any free-form
    // "secure instructions" the parser couldn't classify safely.
    //
    // Doc id mirrors the parent customer slug (customer_secure/{slug}
    // pairs 1:1 with customers/{slug}). The public customer doc
    // carries `hasSecureSop` so other surfaces can show a "secure
    // info exists" affordance without reading this collection.
    //
    // Cleaning techs MUST NOT be able to read this collection.
    // Tech-facing pages (tech.js, today-work.js) never read it
    // and the techHubView server function never returns it.
    //
    // Writes happen via scripts/seedCustomerSopsFromDeputy.js (Admin
    // SDK, bypasses rules) and from admin client edits (Phase 2).
    match /customer_secure/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if isPioneerAdmin();
    }
    match /cleaning_techs/{id} {
      allow read:   if request.auth != null;
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    // DCR submissions contain PII (cleaner names, customer emails, photo +
    // signature URLs, free-text notes about specific premises). Reads are now
    // gated to the admin allowlist — public anonymous reads removed.
    //
    // submitDcrV1 (the only writer) uses the Admin SDK and bypasses these
    // rules, so the public form continues to submit without auth. Direct
    // client-SDK writes stay denied across the board; archive isn't relevant
    // here (submissions are append-only operational records).
    match /dcr_submissions/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // Supply requests are an operational workflow — admins read AND edit
    // them from /admin.html. Auto-creation is also done by submitDcrV1 via
    // the Admin SDK, which bypasses these rules. Deletes are denied
    // outright — workflow is "close it", not "delete it".
    match /supply_requests/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Help Improve Pioneer — operational improvement channel + separate
    // protected concerns channel.
    //
    //   submission_type == "improvement"  — visible to admins; the
    //     submitter can read their own doc. Identity is required (the
    //     team's culture is ownership, not anonymous venting).
    //
    //   submission_type == "protected"   — harassment / discrimination /
    //     retaliation / ethics-safety. Visible ONLY to the named admin
    //     allowlist (Nick + April + Kirby + Mara). Anonymity is at the
    //     submitter's discretion via the `is_anonymous` flag; uid/email
    //     are still server-stamped for serious-followup audit, but the
    //     admin UI hides them when is_anonymous=true.
    //
    // Create gate (both types):
    //   • request.auth must be set
    //   • submitted_by_uid / email must match the auth token
    //   • status must be "submitted" on create
    //   • doc_id must equal submission_id
    //
    // Updates: admins only (status workflow + admin_notes).
    // Deletes: denied — protected concerns must remain auditable; standard
    //   improvements close via status, not delete.
    function canReadImprovement() {
      return request.auth != null
        && (
          isPioneerAdmin()
          || (
            resource.data.submission_type == "improvement"
            && resource.data.submitted_by_uid == request.auth.uid
          )
        );
    }
    match /pioneer_improvements/{id} {
      allow read:   if canReadImprovement();
      // Pilot v20260528-archived-revoke — Help Improve Pioneer requires
      // an active cleaning_techs/admin row.
      allow create: if isActiveStaff()
                    && request.auth.token.email is string
                    && request.resource.data.submission_id == id
                    && request.resource.data.submitted_by_uid == request.auth.uid
                    && request.resource.data.submitted_by_email == request.auth.token.email.lower()
                    && request.resource.data.status == "submitted"
                    && request.resource.data.submission_type in ["improvement", "protected"]
                    && (request.resource.data.submission_type == "improvement"
                          ? request.resource.data.is_protected == false
                          : request.resource.data.is_protected == true);
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Pioneer SOS — Phase 1 lone-worker protection.
    //
    // Create: any signed-in staff can write a new event. We require
    //   createdByUid + createdByEmail to match the auth token (so a
    //   spoofed payload can't mis-attribute the alert), status="open",
    //   and severity in {"help_needed", "critical"}. Initial notified
    //   map is enforced to zeros — only the Cloud Function (Admin SDK)
    //   bypasses these rules to stamp the real notification result.
    //
    // Read / update: admin-only — SOS events carry geolocation + tech
    //   identity + free-text details and must NOT be readable by other
    //   field techs.
    //
    // Delete: denied — emergency records must remain auditable.
    match /emergency_events/{id} {
      allow read:   if isPioneerAdmin();
      // Pilot v20260528-archived-revoke — only active staff can fire SOS.
      // Archived/deleted techs are routed to the access-denied UI before
      // reaching the SOS surface, but the rule is the source of truth.
      allow create: if isActiveStaff()
                    && request.auth.token.email is string
                    && request.resource.data.createdByUid == request.auth.uid
                    && request.resource.data.createdByEmail == request.auth.token.email.lower()
                    && request.resource.data.status == "open"
                    && request.resource.data.severity in ["help_needed", "critical"]
                    && request.resource.data.notified.april == false
                    && request.resource.data.notified.kirby == false
                    && request.resource.data.notified.nick  == false
                    && request.resource.data.notificationStatus == "pending";
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Pioneer config — read-only customer-facing values like emergency
    // contact phone numbers. Admin writes via Firestore console; field
    // techs never read this directly (the SOS function reads it server
    // side via Admin SDK).
    match /pioneer_config/{key} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if isPioneerAdmin();
    }

    // DCR-derived issues — auto-created by submitDcrV1 (Admin SDK) when
    // a submission contains checklist items in `issue` state or a
    // problem-section report. Backlog for office triage with status
    // workflow new → reviewed → customer_contacted → resolved /
    // closed_no_action. Admins read + update workflow fields. Public
    // form and Tech Hub get ZERO access — admin_notes and triage history
    // would leak sensitive context otherwise. Client-SDK creates are
    // denied; only the submitDcrV1 server path materialises docs.
    match /dcr_issues/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if false;
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Supply-order notifications — created by the admin client when a
    // supply request hits the "PCC will order" status, so an external
    // system (Zapier, etc.) can text/Slack the supply ops contact and
    // drive 48-hour follow-up reminders. ALSO created server-side by
    // submitSupplyStationOrderV1 (Admin SDK bypasses rules) when a
    // staff member submits a supply-station order. Contains contact
    // phone — must stay admin-only, never readable by tech-facing pages
    // or the public DCR form. Admins create + update (notification_status,
    // reminder counters, resolved_at); reads are admin-only so the
    // Zapier service account or an admin Custom Token can poll. Deletes
    // denied — closed notifications stay for audit (resolved_at set).
    match /supply_notifications/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Supply Station orders — tech-submitted requests for restocking the
    // central supply station. Writes go through submitSupplyStationOrderV1
    // (Admin SDK), so client-SDK creates/updates are denied here. Reads
    // are admin-only (tech-facing pages only need the write path; they
    // don't read other techs' orders). Deletes denied — workflow is
    // "close it", not "delete it".
    match /supply_station_orders/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if false;
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Announcements — admin-authored messages broadcast to all signed-in
    // staff. Surfaces on Pioneer Team Hub as cards, plus a small unread
    // badge on the Team Hub nav pill across every staff page. Mandatory
    // announcements pop a blocking modal that requires "Mark as read".
    //
    // Read access is intentionally broad (any signed-in user) — the
    // content is meant to be seen by every active staff member. Admins
    // own create/update; deletes are denied because the workflow is
    // "archive" (set archived_at + active=false) rather than "delete".
    match /announcements/{id} {
      // V2: targeted announcements. Pre-targeting docs (no audienceType)
      // are treated as "all" for back-compat — the existing all-team
      // announcements stay readable to every signed-in user.
      function canReadAnnouncement() {
        return request.auth != null && (
          isPioneerAdmin()
          || !("audienceType" in resource.data)
          || resource.data.audienceType == "all"
          || (resource.data.audienceType == "selected" && (
                (resource.data.recipientUids is list
                  && request.auth.uid in resource.data.recipientUids)
                || (resource.data.recipientEmails is list
                    && request.auth.token.email is string
                    && request.auth.token.email.lower() in resource.data.recipientEmails)
             ))
        );
      }
      allow read:   if canReadAnnouncement();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;

      // Per-user recipient_status subcollection. The doc id is the
      // user's uid. Each staff user can read + write ONLY their own
      // doc (with a uid match check on payload); admins can read all
      // (for the admin recipient-status panel).
      match /recipient_status/{uid} {
        allow read:   if isPioneerAdmin()
                      || (request.auth != null && request.auth.uid == uid);
        // Acknowledge / viewed / replied requires active-staff status.
        // Archived techs can't update their own ack timeline.
        allow create, update:
                      if isActiveStaff()
                      && request.auth.uid == uid
                      && request.resource.data.uid == request.auth.uid;
        allow delete: if false;
      }

      // Comments subcollection. Read gated to anyone who can read the
      // parent announcement; create only when the writer matches the
      // auth token. Admin can update/delete for moderation if a thread
      // ever gets out of hand. Field techs can never delete (audit).
      match /comments/{commentId} {
        function canReadParent() {
          return request.auth != null && (
            isPioneerAdmin()
            || !("audienceType" in get(/databases/$(database)/documents/announcements/$(id)).data)
            || get(/databases/$(database)/documents/announcements/$(id)).data.audienceType == "all"
            || (get(/databases/$(database)/documents/announcements/$(id)).data.audienceType == "selected" && (
                  (get(/databases/$(database)/documents/announcements/$(id)).data.recipientUids is list
                    && request.auth.uid in get(/databases/$(database)/documents/announcements/$(id)).data.recipientUids)
                  || (get(/databases/$(database)/documents/announcements/$(id)).data.recipientEmails is list
                      && request.auth.token.email is string
                      && request.auth.token.email.lower() in get(/databases/$(database)/documents/announcements/$(id)).data.recipientEmails)
               ))
          );
        }
        allow read:   if canReadParent();
        // Reply requires active-staff status — archived techs can't post.
        allow create: if isActiveStaff()
                      && canReadParent()
                      && request.resource.data.createdByUid == request.auth.uid
                      && request.auth.token.email is string
                      && request.resource.data.createdByEmail == request.auth.token.email.lower();
        allow update: if isPioneerAdmin();
        allow delete: if isPioneerAdmin();
      }
    }

    // Announcement reads — one doc per (announcement, user) pair so we
    // can compute "unread for this user" without leaking other users'
    // read state. Doc ID convention is `{announcement_id}_{uid}` which
    // both makes upserts idempotent AND lets the rules confirm the doc
    // ID matches the requesting user's uid.
    //
    // - Read: admins can read all (for future analytics);
    //         each staff user can read their own docs only.
    // - Create / Update: staff can write their OWN doc only (uid in
    //   payload must match request.auth.uid AND doc id must follow the
    //   `{announcement_id}_{uid}` convention). Update is allowed so a
    //   client-side `set()` call (which Firestore's Web SDK uses for
    //   "create or overwrite") doesn't error if the doc already exists
    //   — re-reads are idempotent.
    // - Delete: denied. Read state is append-once.
    match /announcement_reads/{readId} {
      allow read: if isPioneerAdmin() ||
                     (request.auth != null && resource.data.uid == request.auth.uid);
      allow create, update:
                  if request.auth != null
                  && request.resource.data.uid == request.auth.uid
                  && readId == request.resource.data.announcement_id + "_" + request.auth.uid;
      allow delete: if false;
    }

    // Team Schedule — single-doc (team_schedule/current) holding a
    // pointer to the latest team-schedule PDF/image in Storage. Admins
    // upload via the Admin → Schedule panel; every signed-in staff
    // member (admin + cleaning_tech) can read it on Team Hub.
    //
    // The Storage rules block at `team-schedules/**` is the matching
    // bytes-level gate. Schema (lightweight, pilot-ready):
    //   fileName, storagePath, downloadUrl, contentType, byteSize,
    //   uploadedAt, uploadedBy { uid, email, displayName },
    //   effectiveMonth (optional, "YYYY-MM"), notes (optional),
    //   active (bool, default true).
    //
    // Phase 2 TODO (intentionally out of scope here):
    //   • native Deputy monthly schedule sync (overwrite this doc from
    //     a scheduled function)
    //   • team_schedule history collection (one doc per upload) for
    //     auditing + a "previous schedules" archive
    //   • per-tech / per-customer filtered calendar views
    match /team_schedule/{id} {
      allow read:   if request.auth != null;
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // ====================================================================
    // Attendance — call_outs + time_off_requests
    // ====================================================================
    // Two separate collections so the urgent "I can't come in tonight"
    // path stays distinct from the planned "I want July 4 off" path.
    // Office manager (Kirby et al.) reviews both via Admin → Attendance.
    //
    // Schema lives in the matching public/call-out.js + public/time-off.js
    // submit handlers. Key field: `techUid` (Firebase Auth uid) — used
    // by the own-read rule below so techs can see their own status
    // without leaking other techs' attendance data.
    //
    // Phase 2 TODO:
    //   • Cloud Function trigger on create → email Kirby
    //   • notification doc on approve/deny → tech sees status update
    //   • blackout windows (e.g., end-of-quarter freeze)
    match /call_outs/{id} {
      allow read:   if isPioneerAdmin()
                    || (request.auth != null
                        && resource.data.techUid is string
                        && resource.data.techUid == request.auth.uid);
      // Techs create their own call-out: must be an ACTIVE cleaning_tech,
      // uid must match payload, status must start at "new". Admins can
      // also create (e.g., logging a phoned-in call-out).
      allow create: if (isActiveCleaningTech()
                        && request.resource.data.techUid == request.auth.uid
                        && request.resource.data.status == "new")
                    || isPioneerAdmin();
      // Only admins move call-outs through acknowledged → resolved.
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    match /time_off_requests/{id} {
      // Read access is intentionally open to any signed-in staff so
      // techs can see the "Scheduled Time Off" coverage heatmap on
      // /team-schedule before submitting their own request. Names +
      // dates are operationally needed for coverage planning; we
      // treat this as scheduling-sibling visibility, not privacy
      // data. Call-outs stay admin+own (different sensitivity).
      allow read:   if request.auth != null;
      // Techs request their own time off: must be an ACTIVE cleaning_tech,
      // uid must match payload, status must start at "pending". Admins
      // can also create (e.g., logging an in-person request).
      allow create: if (isActiveCleaningTech()
                        && request.resource.data.techUid == request.auth.uid
                        && request.resource.data.status == "pending")
                    || isPioneerAdmin();
      // Only admins approve/deny + add manager note.
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    // Open shift coverage requests + Rockstar bonus ledger.
    // ====================================================================
    // open_shift_requests/{id}
    //   Admin (or a call-out conversion flow) creates an "open shift"
    //   doc with status="open". Techs accept by flipping to
    //   "accepted" + stamping their own uid. The rule below is the
    //   atomic-claim gate: a second tech's accept request fails
    //   because the doc's prior status is no longer "open".
    //
    //   Admins confirm coverage (status="confirmed") which kicks off
    //   a Rockstar bonus write — done client-side as a Firestore
    //   batch in admin.js so the two writes succeed or fail together.
    //
    //   Phase 2 TODO:
    //     • Cloud Function trigger on create → write an
    //       `announcements/{id}` doc so the Team Hub Announcements
    //       feed surfaces open shifts natively (currently the Team
    //       Hub card just shows a badge with open count)
    //     • Auto-cancel + Kirby alert when an open shift remains
    //       unclaimed past its shiftDate
    //     • Per-tech decline / waitlist
    match /open_shift_requests/{id} {
      allow read:   if request.auth != null;
      allow create: if isPioneerAdmin();
      // Two update paths:
      //   1. Admin can flip the doc to any state (cancel / confirm /
      //      edit) and stamp their own identity.
      //   2. Tech can claim an open shift by flipping
      //      status:"open" → "accepted" AND stamping their own uid in
      //      acceptedByTechUid. Rules-enforced atomic claim — the
      //      second concurrent attempt fails because resource.data
      //      (the PRE-write state) no longer reads "open".
      allow update: if isPioneerAdmin()
                    || (isActiveCleaningTech()
                        && resource.data.status == "open"
                        && request.resource.data.status == "accepted"
                        && request.resource.data.acceptedByTechUid is string
                        && request.resource.data.acceptedByTechUid == request.auth.uid);
      allow delete: if false;
    }

    // rockstar_bonuses/{id}
    //   Created when an admin confirms an open shift. Read-open so
    //   the Team Hub "Rockstar Team Players this month" recognition
    //   can render counts to all signed-in staff. The amount field
    //   is $25 for everyone — public knowledge per the pilot — so
    //   we don't gate that behind admin-only reads. Bonus status
    //   (pending/approved/paid) stays admin-managed.
    match /rockstar_bonuses/{id} {
      allow read:   if request.auth != null;
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Simple notification surface — for now just a badge on Admin.
    // Each doc represents an event the office team should see. Read
    // is admin-only; create happens client-side at the same time
    // as the call-out / time-off doc (best-effort; rules just gate it).
    // Phase 2: replace with a Cloud Function fan-out + email.
    match /notifications/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if request.auth != null
                    && request.resource.data.createdByUid == request.auth.uid;
      allow update: if isPioneerAdmin();
      allow delete: if isPioneerAdmin();
    }

    // Published Team Schedule (Deputy-powered) — single-doc
    // (published_team_schedule/current) holding a normalized snapshot of
    // the next 14 days of Deputy shifts. Admins click "Publish" in the
    // admin Schedule tab; that builds the snapshot from
    // deputy_shift_cache and overwrites this doc. Team Hub reads the
    // doc to render an "Upcoming Team Schedule" grouped-by-day view.
    //
    // Deliberate snapshot model: Team Hub does NOT reflect every live
    // Deputy edit. Admins publish when ready. Each publish overwrites
    // the doc; there is no per-publish history collection yet.
    //
    // Schema (mirrors public/admin.js publishTeamSchedule):
    //   publishedAt           (serverTimestamp)
    //   publishedBy           ({uid, email, displayName})
    //   startDate, endDate    (YYYY-MM-DD Pacific)
    //   deputySyncVersion     (string|null, future use)
    //   shiftCount            (number)
    //   shifts                (array of normalized shift objects:
    //                          {date, weekday, startTime, endTime,
    //                          startMs, endMs, techName, techSlug,
    //                          customerName, customerSlug, status,
    //                          deputyShiftUrl})
    //   notes                 (string|null)
    //   active                (bool, default true)
    //
    // Phase 2 TODO (intentionally out of scope here):
    //   • monthly calendar view + printable export
    //   • personal "my schedule" filtering for cleaning techs
    //   • shift swaps + PTO overlays + open-shift coverage flags
    //   • live vs deferred publish modes (currently always deferred)
    //   • per-publish history subcollection for audit + rollback
    //   • server-side publish (Cloud Function) so the snapshot can be
    //     built even when no admin browser is open
    match /published_team_schedule/{id} {
      allow read:   if request.auth != null;
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Admin allowlist (Firestore-backed). One doc per admin, doc ID is
    // the lowercased email. Admin client (admin.js) reads this to
    // decide whether the signed-in user can access /admin; rules use
    // it via isPioneerAdmin() above for write gates on every admin-
    // managed collection.
    //
    // Reads: any signed-in user can read their OWN admin doc (so the
    // admin client can verify the active flag); admins can read all
    // (for the Admins tab listing). Writes: admin-only — including
    // self, so an admin can reactivate themselves but not create
    // others without going through createAdminLoginV1 (which uses
    // the Admin SDK, bypassing rules).
    match /admins/{email} {
      allow read: if isPioneerAdmin()
                  || (request.auth != null
                      && request.auth.token.email is string
                      && request.auth.token.email.lower() == email);
      allow create, update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Inspections — quality-audit records. ADMIN-ONLY for create/read/
    // update. The previous create rule was permissive (any signed-in
    // staff with own uid) on the assumption an explicit "inspector"
    // role would land soon and on the UI being the gate. Production
    // audit flagged this as a soft-gate — Web SDK callers could bypass
    // the inspections.js admin check — so we tightened create to
    // isPioneerAdmin() to match the UI. When the inspector role lands,
    // relax the create rule via an OR clause; do NOT remove the
    // identity guards below.
    //
    // Field validation on create:
    //   • inspector_uid must equal request.auth.uid (no impersonation)
    //   • customer_slug must be a non-empty kebab-ish string
    //   • status fields are admin-only — clients only write the
    //     initial submission shape.
    //   • Deletes denied entirely. Inspections are immutable history;
    //     admin can soft-archive via active=false in a future build.
    match /inspections/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin()
                    && request.auth.token.email is string
                    && request.resource.data.inspector_uid == request.auth.uid
                    && request.resource.data.customer_slug is string
                    && request.resource.data.customer_slug.size() > 0
                    && request.resource.data.customer_slug.size() < 80;
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Quality Wins — durable record of 5-star inspections that the
    // company is celebrating. Auto-created by inspections.js when an
    // admin submits an inspection with overall_score >= 4.8. Stays
    // intentionally morale-positive: read access is open to any active
    // staff member (it's a "company brag wall"), but writes are
    // admin-only and we don't allow deletes — once celebrated, the
    // record stays for the audit trail. Soft-archive via active=false
    // if a win ever needs to be retracted.
    match /quality_wins/{id} {
      allow read: if request.auth != null;
      // Two creation paths now:
      //   • Inspection-derived wins (the original) — require
      //     inspection_id + customer_slug + overall_score >= 4.8.
      //   • Customer-compliment wins (written server-side by
      //     submitFeedbackV1 with source == "customer_compliment").
      //     Admin SDK bypasses these rules at write time, so this
      //     branch only exists to document the contract — the test
      //     here also allows admin-tagged compliment shapes to pass
      //     if anyone ever calls the SDK from a client.
      allow create: if isPioneerAdmin()
                    && (
                      (
                        request.resource.data.inspection_id is string
                        && request.resource.data.inspection_id.size() > 0
                        && request.resource.data.customer_slug is string
                        && request.resource.data.customer_slug.size() > 0
                        && request.resource.data.overall_score is number
                        && request.resource.data.overall_score >= 4.8
                      ) || (
                        request.resource.data.source == "customer_compliment"
                        && request.resource.data.customer_slug is string
                        && request.resource.data.overall_score is number
                        && request.resource.data.overall_score >= 4
                      )
                    );
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // DCR email payloads. Written by generateAndSendDcrEmailV1 (Admin
    // SDK, bypasses rules). Admin-read enables the Today's Operations
    // dashboard to query sent/failed counts in the last 24h without
    // an extra Cloud Function round-trip. Doc ID is the DCR id; one
    // payload per DCR. Client writes/deletes denied — only the send
    // function should mutate these.
    match /dcr_email_payloads/{id} {
      allow read:   if isPioneerAdmin();
      allow create, update, delete: if false;
    }

    // Customer feedback (universal record — both compliments and
    // complaints). Written ONLY by submitFeedbackV1 via the Admin SDK,
    // which bypasses these rules. Client-side reads gated to admins so
    // the admin dashboard can render the feedback inbox. No client
    // writes, no client deletes.
    match /customer_feedback/{id} {
      allow read:   if isPioneerAdmin();
      allow create, update, delete: if false;
    }

    // Customer complaints — operational follow-up records. Same write
    // model as customer_feedback (Admin SDK only). Admin reads allowed
    // for the office triage view. Updates are intentionally denied so
    // status flips have to go through a dedicated admin function once
    // it's built — keeps the audit trail clean.
    match /customer_complaints/{id} {
      allow read:   if isPioneerAdmin();
      allow create, update, delete: if false;
    }

    // In-system notifications. Most writes happen via Admin SDK
    // (submitFeedbackV1, sendDcrEmailCore) which bypasses these
    // rules. V6 pilot adds one narrowly-gated CLIENT write path:
    // techs can create `type: "supply_update_request"` notifications
    // ("Ask Kirby for update") under strict shape validation so the
    // surface can't be abused for arbitrary office-inbox spam.
    match /notifications/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if request.auth != null
                    && request.auth.token.email is string
                    && request.resource.data.type == "supply_update_request"
                    && request.resource.data.requestedBy == request.auth.token.email.lower()
                    && request.resource.data.status == "update_requested"
                    && request.resource.data.supplyRequestId is string
                    && request.resource.data.supplyRequestId.size() > 0
                    && request.resource.data.supplyRequestId.size() < 200;
      allow update, delete: if false;
    }

    // Service Recoveries — coaching + follow-up tasks tied to a
    // customer (and optionally an inspection). Intentionally NOT
    // "customer issues" or "tickets" — the operational concept here
    // is service recovery: how the office makes a situation right.
    //
    // Rules:
    //   read   — admins all; assigned tech sees only their own
    //            (matched on assigned_to_email, lowercased).
    //   create — admin only. Field validation:
    //              • status must start as "open"
    //              • customer_slug is a non-empty string AND the
    //                matching /customers/{slug} doc exists.
    //   update — admin only. Used for status flips, assignment
    //            changes, resolution notes.
    //   delete — denied. Recovery records are part of the coaching
    //            audit trail.
    match /service_recoveries/{id} {
      allow read: if isPioneerAdmin()
                  || (request.auth != null
                      && request.auth.token.email is string
                      && resource.data.assigned_to_email is string
                      && request.auth.token.email.lower() == resource.data.assigned_to_email);
      allow create: if isPioneerAdmin()
                    && request.resource.data.status == "open"
                    && request.resource.data.customer_slug is string
                    && request.resource.data.customer_slug.size() > 0
                    && exists(/databases/$(database)/documents/customers/$(request.resource.data.customer_slug));
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Customer cleaning notes — tribal operational knowledge for a
    // specific customer/location (security/access/cleaning preferences/
    // sensitive areas/etc.). Read access for techs goes through
    // techHubViewV1 (server-gated by the tech's assigned_customer_slugs)
    // so we deliberately keep direct client reads admin-only — preserves
    // the existing "tech can only see their assigned customers" gate
    // without having to denormalize authorized_emails onto every note.
    //
    // Writes are admin-only. Soft-delete via active=false; hard delete
    // denied so the audit trail of historic notes stays intact.
    match /customer_notes/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Customer note SUGGESTIONS — read-and-forget queue items techs
    // submit when they spot a missing or stale note. Admins review +
    // either apply changes to /customer_notes or reject.
    //
    // Rules:
    //   read   — admins all; tech sees only their own submissions
    //            (matched by suggested_by_uid == request.auth.uid).
    //   create — any signed-in user. Validates:
    //              • status starts as "pending"
    //              • suggested_by_uid matches the auth uid (techs can't
    //                impersonate someone else)
    //              • suggested_by email matches the lowercased token email
    //              • customer_slug is a non-empty string AND the matching
    //                /customers/{customer_slug} doc actually exists
    //                (cross-check via exists()).
    //              • suggested_change is a non-empty string
    //   update — admin only (for status/reviewed_by/reviewed_at).
    //   delete — denied. Suggestions are append-only.
    match /customer_note_suggestions/{id} {
      allow read: if isPioneerAdmin()
                  || (request.auth != null
                      && resource.data.suggested_by_uid == request.auth.uid);
      allow create: if request.auth != null
                    && request.auth.token.email is string
                    && request.resource.data.status == "pending"
                    && request.resource.data.suggested_by_uid == request.auth.uid
                    && request.resource.data.suggested_by == request.auth.token.email.lower()
                    && request.resource.data.customer_slug is string
                    && request.resource.data.customer_slug.size() > 0
                    && request.resource.data.customer_slug.size() < 80
                    && request.resource.data.suggested_change is string
                    && request.resource.data.suggested_change.size() > 0
                    && request.resource.data.suggested_change.size() < 4000
                    && exists(/databases/$(database)/documents/customers/$(request.resource.data.customer_slug));
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Deputy shift cache — written by syncDeputyShiftsV1 / refreshDeputyShiftsV1
    // via the Admin SDK (bypasses these rules). Read access is split:
    //   • admins see the full set (for "Today's shifts" admin view)
    //   • each tech sees only their own shifts, matched on the doc's
    //     employee_email field vs request.auth.token.email
    // No client-side writes — Deputy is the source of truth.
    match /deputy_shift_cache/{id} {
      // V6 pilot — three read arms (any one is sufficient):
      //   1. admin override (isPioneerAdmin)
      //   2. direct email match: shift's employee_email == auth.email
      //   3. tech-slug fallback: shift's employee_slug links to a
      //      cleaning_techs doc whose email matches the auth user.
      //      Covers the regression where the Deputy sync wrote
      //      employee_email="" because the matched tech's cleaning_techs
      //      doc had no email field. Once the office adds the email,
      //      the tech can read their shifts without waiting for a
      //      full Deputy resync.
      function shiftTechSlugLinksToAuth() {
        return request.auth != null
          && request.auth.token.email is string
          && resource.data.employee_slug is string
          && resource.data.employee_slug.size() > 0
          && exists(/databases/$(database)/documents/cleaning_techs/$(resource.data.employee_slug))
          && get(/databases/$(database)/documents/cleaning_techs/$(resource.data.employee_slug)).data.email is string
          && get(/databases/$(database)/documents/cleaning_techs/$(resource.data.employee_slug)).data.email.lower() == request.auth.token.email.lower();
      }
      allow read: if isPioneerAdmin()
                  || (request.auth != null
                      && request.auth.token.email is string
                      && resource.data.employee_email is string
                      && resource.data.employee_email.size() > 0
                      && request.auth.token.email.lower() == resource.data.employee_email)
                  || shiftTechSlugLinksToAuth();
      allow create, update, delete: if false;
    }

    // Operational feed — structured, action-linked communication
    // stream that replaces ad-hoc Slack threads for the supply /
    // shift / inspection / safety / recognition / scheduler /
    // hiring / training / policy categories.
    //
    // Phase 1 access model:
    //   • Admins (isPioneerAdmin) — full read / create / update.
    //   • Other signed-in users — read if their uid is in
    //     `audience_user_ids`. The `audience_roles` field is data-only
    //     for Phase 1 (no role tables exist yet beyond admin + tech);
    //     future phases will fan out audience_user_ids server-side
    //     based on role tables.
    //   • Non-admin update — only the ack + status pair, gated to the
    //     limited set of fields below. Title / body / audience /
    //     severity remain admin-only.
    //   • Delete — denied. Use status: "archived" instead.
    match /operational_feed/{id} {
      allow read: if isPioneerAdmin() ||
                     (request.auth != null &&
                      resource.data.audience_user_ids is list &&
                      request.auth.uid in resource.data.audience_user_ids);
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin() ||
                       (request.auth != null &&
                        resource.data.audience_user_ids is list &&
                        request.auth.uid in resource.data.audience_user_ids &&
                        request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasOnly(["acknowledged_by", "status", "updated_at"]));
      allow delete: if false;
    }

    // Supply notices — admin-only awareness layer for the supply
    // request work queue. One doc is written by submitDcrV1 +
    // submitSupplyStationOrderV1 (Admin SDK, bypasses rules) for
    // every new supply request. The admin Supply panel reads this
    // collection to render a "Recent supply notices" disclosure.
    //
    // Techs and customers never read or write this — it's a private
    // operational signal carrying Kirby's assignment and the source
    // supply request id.
    match /supply_notices/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if false;   // server-side only
      allow update: if isPioneerAdmin();   // admin can ack / archive
      allow delete: if false;
    }

    // Customer aliases — Pioneer-curated lookup table that maps a
    // free-form alias (Pioneer abbreviation, Deputy bracket code, OU
    // name fragment, etc.) to a Pioneer customer slug. One row per
    // alias; the Deputy sync reads this collection to populate the
    // suggested_customer_* fields on shift cache docs. Admin-only.
    //
    // Doc shape:
    //   alias              — display string (e.g. "NOTL", "Note and Kidd")
    //   normalized_alias   — lowercased / non-alnum stripped (also the doc id)
    //   customer_slug
    //   customer_name
    //   active             — boolean; admin can soft-disable without deleting
    //   source             — "manual_seed" | "admin_created" | "learned"
    //   confidence         — "high" (only level currently used)
    //   created_at, updated_at
    match /customer_aliases/{alias} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin()
                    && request.resource.data.customer_slug is string
                    && request.resource.data.customer_slug.size() > 0
                    && request.resource.data.alias is string
                    && request.resource.data.alias.size() > 0
                    && exists(/databases/$(database)/documents/customers/$(request.resource.data.customer_slug));
      allow update: if isPioneerAdmin()
                    && request.resource.data.customer_slug is string
                    && request.resource.data.customer_slug.size() > 0
                    && exists(/databases/$(database)/documents/customers/$(request.resource.data.customer_slug));
      allow delete: if isPioneerAdmin();
    }

    // Pioneer work sessions — the operational workflow layer on top of
    // Deputy. One doc per Deputy shift the tech actually starts. Doc
    // ID == deputy_shift_id (1:1 with the cache doc, deterministic so
    // re-renders don't race).
    //
    // Status workflow: not_started → working → needs_finish → finished
    //   • Client writes "working" (start work) + "finished" (finish work).
    //   • submitDcrV1 (Admin SDK) writes "needs_finish" + dcr_submission_id
    //     after a DCR is saved for the linked deputy_shift_id.
    //
    // PeakOps NOTE: this lives entirely inside the pioneer-dcr-hub project
    // and has no PeakOps coupling.
    //
    // Rules:
    //   read   — admins see all; tech sees their own (matched by tech_email).
    //   create — tech is the SAME user whose email is on the new doc AND
    //            the linked deputy_shift_cache doc also belongs to them.
    //            Cross-check via get() on /deputy_shift_cache/{shiftId}
    //            so a tech can't create sessions for someone else's shift.
    //   update — tech can update their own session; tech_email and
    //            deputy_shift_id are immutable (the user can't rebind a
    //            session to a different shift / employee). Admins can
    //            update everything for ops triage.
    //   delete — denied. Sessions are append-only audit trail.
    match /pioneer_work_sessions/{shiftId} {
      // V7 pilot fix — single ownership source.
      //
      // The previous rule referenced `resource.data.tech_email` in the
      // read gate, which silently denied reads of NON-EXISTENT session
      // docs (because `resource` is null pre-create). startWork() runs
      // a transaction that calls `tx.get(ref)` before the set — that
      // read was being denied, producing a "permission-denied" with
      // no diagnostic. Pilot blocker: Makaila on Lydig shift 5796.
      //
      // The new rule treats `deputy_shift_cache/{shiftId}.employee_email`
      // as the canonical "who owns this shift" record. Reads + writes
      // both gate on the same predicate, so existing session docs and
      // first-time-create flows work identically. The fallback to the
      // session doc's own tech_email is kept for the rare case where
      // a session pre-dates a cache rebuild and the deputy cache no
      // longer holds the original row.
      function shiftBelongsToCaller() {
        return request.auth != null
          && request.auth.token.email is string
          && exists(/databases/$(database)/documents/deputy_shift_cache/$(shiftId))
          && get(/databases/$(database)/documents/deputy_shift_cache/$(shiftId)).data.employee_email == request.auth.token.email.lower();
      }
      function sessionBelongsToCaller() {
        return request.auth != null
          && request.auth.token.email is string
          && resource != null
          && resource.data.tech_email is string
          && request.auth.token.email.lower() == resource.data.tech_email;
      }
      allow read:   if isPioneerAdmin()
                    || shiftBelongsToCaller()
                    || sessionBelongsToCaller();
      // Pilot v20260528-archived-revoke — Start Work / Finish Work both
      // require the caller's cleaning_techs row to still be active.
      // Archived techs hit the rule denial and the page surfaces the
      // friendly access-removed message via STAFF_AUTH's whoAmI cycle.
      allow create: if isActiveStaff()
                    && request.auth.token.email is string
                    && request.auth.token.email.lower() == request.resource.data.tech_email
                    && request.resource.data.deputy_shift_id == shiftId
                    && shiftBelongsToCaller();
      allow update: if isPioneerAdmin()
                    || (isActiveCleaningTech()
                        && sessionBelongsToCaller()
                        && request.resource.data.tech_email == resource.data.tech_email
                        && request.resource.data.deputy_shift_id == resource.data.deputy_shift_id);
      allow delete: if false;
    }

    // Active-staff index. Tiny shadow doc per active cleaning tech +
    // admin, keyed by lowercase email. The isActiveCleaningTech() rule
    // checks for the doc's existence + active flag, so an archived
    // tech (active flipped to false) loses every field-write gate
    // without scanning cleaning_techs.
    //
    // Writes happen ONLY through the admin tech archive/reactivate flow
    // and the createCleaningTechLoginV1 Cloud Function. No client-side
    // writes are allowed.
    match /active_techs_by_email/{email} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if isPioneerAdmin();
    }

    // Deputy OAuth state — holds access/refresh tokens and the brief
    // pending-state doc used for CSRF protection during the
    // authorize→callback round trip. Server-only via Admin SDK; clients
    // get zero access. (The default-deny rule at the bottom already
    // covers this collection, but we declare the rule explicitly so
    // future readers don't wonder.)
    match /deputy_oauth_state/{id} {
      allow read, write: if false;
    }

    // Safety Training — per-user progress records.
    //
    // Storage layout: users/{uid}/training_progress/{lessonId}
    //   • lessonId, status: "in_progress"|"completed", score: 0..100|null,
    //     acknowledgmentSignedAt, acknowledgmentText, userAgent,
    //     completedAt, updatedAt, signedName, uid, email, displayName.
    //
    // Read:   the owning user, or any Pioneer admin (for reports).
    // Write:  the owning user only (no admin impersonation).
    // Delete: denied — training records are append-only audit history.
    //
    // The parent users/{uid} doc itself is not used by the app yet, so
    // we don't grant read/write on it — only the subcollection rule
    // below applies. Lesson metadata is a static JSON file in
    // public/data/training-lessons.json served via Firebase Hosting;
    // no Firestore rule is needed for catalog reads.
    match /users/{uid}/training_progress/{lessonId} {
      allow read:   if request.auth != null
                      && (request.auth.uid == uid || isPioneerAdmin());
      allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.lessonId == lessonId;
      allow update: if request.auth != null
                      && request.auth.uid == uid
                      && request.resource.data.lessonId == lessonId;
      allow delete: if false;
    }
    // Admin training reports use a collectionGroup("training_progress")
    // read so a single query returns every user's progress in one go.
    // CollectionGroup queries match by the trailing path segment
    // pattern below. Restricted to admins; default-deny otherwise.
    match /{path=**}/training_progress/{lessonId} {
      allow read: if isPioneerAdmin();
    }

    // ====================================================================
    // PioneerOps native time clock — Phase 1a foundation collections.
    // ====================================================================
    // service_assignments: what a tech is supposed to do today.
    // pioneer_service_sessions: one clock-in/clock-out cycle per assignment.
    // active_service_sessions: doc-id-keyed lookup that enforces "at most
    //   one active session per staff" via atomic create/delete in the
    //   same transaction as the session write.
    // time_punches: append-only audit log of every clock-in/out event.
    // drive_segments: model only in Phase 1; auto-population in Phase 2.
    // payroll_periods: semi-monthly cadence (1-15 / 16-EOM). Admin-managed.
    // sick_leave_ledger: append-only audit ledger; minutes_delta in INTEGER
    //   minutes (positive = credit, negative = debit). Entry types:
    //   opening_balance, earned, used, admin_adjustment. (Phase 2 adds
    //   carryover, carryover_forfeit.)
    // staff_labor_balances: materialized cache of ledger sums; doc id =
    //   staff_uid. Writes restricted to admin OR the staff themselves
    //   (whitelisted current_period_* counters only).

    function isOwnUid(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /service_assignments/{assignmentId} {
      allow read:   if isPioneerAdmin()
                    || (request.auth != null
                        && resource.data.staff_uid == request.auth.uid);
      allow create, update: if isPioneerAdmin();
      allow delete: if false;  // soft-cancel via status field
    }

    match /pioneer_service_sessions/{sessionId} {
      allow read:   if isPioneerAdmin()
                    || (request.auth != null
                        && resource.data.staff_uid == request.auth.uid);
      // Tech creates their own active session at clock-in.
      allow create: if isActiveStaff()
                    && request.resource.data.staff_uid == request.auth.uid
                    && request.resource.data.status == "active"
                    && request.resource.data.clock_out_at == null;
      // Update: admin override, OR own + transitioning active → completed.
      allow update: if isPioneerAdmin()
                    || (isOwnUid(resource.data.staff_uid)
                        && resource.data.status == "active"
                        && request.resource.data.status == "completed"
                        && request.resource.data.clock_out_at is timestamp);
      allow delete: if false;
    }

    match /active_service_sessions/{staffUid} {
      allow read:   if isPioneerAdmin() || isOwnUid(staffUid);
      // Create/delete only — never update. Doc id MUST equal staff_uid.
      allow create: if isOwnUid(staffUid)
                    && request.resource.data.staff_uid == staffUid;
      allow update: if false;
      allow delete: if isPioneerAdmin() || isOwnUid(staffUid);
    }

    match /time_punches/{punchId} {
      allow read:   if isPioneerAdmin()
                    || (request.auth != null
                        && resource.data.staff_uid == request.auth.uid);
      allow create: if isActiveStaff()
                    && request.resource.data.staff_uid == request.auth.uid
                    && request.resource.data.punch_type in ["clock_in", "clock_out"]
                    && request.resource.data.punch_at is timestamp;
      // NEVER mutated, NEVER deleted — legal audit record.
      allow update, delete: if false;
    }

    match /drive_segments/{segmentId} {
      allow read:   if isPioneerAdmin()
                    || (request.auth != null
                        && resource.data.staff_uid == request.auth.uid);
      // Phase 1: admin-only writes. Phase 2 Cloud Function uses Admin SDK
      // and bypasses rules for auto-generation.
      allow create, update: if isPioneerAdmin();
      allow delete: if false;
    }

    match /payroll_periods/{periodId} {
      allow read:   if isPioneerAdmin() || isActiveStaff();
      allow create, update: if isPioneerAdmin();
      allow delete: if false;
    }

    match /sick_leave_ledger/{entryId} {
      allow read:   if isPioneerAdmin()
                    || (request.auth != null
                        && resource.data.staff_uid == request.auth.uid);
      // Phase 1 entry types only. minutes_delta is a signed integer;
      // admin_adjustment requires a non-empty reason. Cloud Functions
      // (Admin SDK) bypass these rules for automated entries (e.g. close).
      allow create: if isPioneerAdmin()
                    && request.resource.data.staff_uid is string
                    && request.resource.data.minutes_delta is number
                    && request.resource.data.entry_type in [
                         "opening_balance", "earned", "used", "admin_adjustment"
                       ]
                    && request.resource.data.effective_date is string
                    && (request.resource.data.entry_type != "admin_adjustment"
                        || (request.resource.data.reason is string
                            && request.resource.data.reason.size() > 0));
      // Append-only — corrections happen via NEW admin_adjustment entries.
      allow update, delete: if false;
    }

    match /staff_labor_balances/{staffUid} {
      // Staff can read their own balance doc. Admins can read any.
      allow read: if isPioneerAdmin() || isOwnUid(staffUid);
      // Phase 1a: ADMIN-ONLY writes (seed script via Admin SDK bypasses
      // rules; manual admin tooling goes through this allow-create/update
      // path). Staff cannot mutate balances directly — clock-in/clock-out
      // in Phase 1b writes sessions + punches + active-session lookup
      // ONLY; balance recomputation is deferred to admin tooling or a
      // Phase 2 Cloud Function trigger.
      allow create, update: if isPioneerAdmin();
      allow delete: if false;
    }

    // Phase 28D — payroll_exports: audit log of CSV exports. One doc per
    // export run. Doc id = deterministic export_id. Sole writer is the
    // exportPayrollCsvV1 / voidPayrollExportV1 Cloud Functions via Admin
    // SDK (bypasses these rules). Client reads admin-only; client writes
    // denied so admins can't accidentally corrupt the audit trail outside
    // the function flow.
    match /payroll_exports/{exportId} {
      allow read:   if isPioneerAdmin();
      allow create: if false;  // Cloud Function only
      allow update: if false;  // void goes through voidPayrollExportV1
      allow delete: if false;
    }

    // ====================================================================
    // Phase 29 — Payroll Exception Engine.
    // ====================================================================
    // time_adjustment_requests is the structured replacement for Slack-
    // based payroll corrections. Employees REQUEST adjustments; admins
    // approve / deny. The payroll export reads approved effective times
    // while preserving original clock data on both the request doc and
    // the session doc.
    //
    // Schema (validated where it matters at the boundary — the rest is
    // shape-only and handled by the Cloud Function that writes it):
    //   assignment_id           string                  required
    //   service_session_id      string|null
    //   employee_uid            string  == request.auth.uid on create
    //   employee_email          string
    //   employee_name           string
    //   customer_name           string
    //   location_name           string|null
    //   shift_date              string  YYYY-MM-DD
    //   status                  "pending" on create; admins flip to
    //                           "approved" | "denied" | "canceled"
    //   original_clock_in       Timestamp|null
    //   original_clock_out      Timestamp|null
    //   requested_clock_in      Timestamp
    //   requested_clock_out     Timestamp
    //   original_minutes        number|null
    //   requested_minutes       number
    //   delta_minutes           number
    //   reason                  one of: forgot_clock_in | forgot_clock_out |
    //                                   app_issue | phone_issue | no_internet |
    //                                   emergency | other
    //   notes                   string (required, non-empty)
    //   submitted_at            serverTimestamp
    //   submitted_by_uid        string  == request.auth.uid
    //   created_at, updated_at  serverTimestamp
    //
    // Writes:
    //   create: the employee for their own shift (employee_uid &
    //     submitted_by_uid == auth.uid), status "pending", reason in
    //     the enum, notes non-empty.
    //   update: admin only — to flip status to approved / denied /
    //     canceled and stamp reviewed metadata. Plus the writing
    //     Cloud Function (Admin SDK) bypasses rules entirely.
    //   delete: never. Audit record.
    //
    // Reads:
    //   admin (any), or the submitter (own doc only).
    //
    // Phase 29A — security hardening: ALL writes go through Cloud Functions
    // (createTimeAdjustmentRequestV1 / approveTimeAdjustmentRequestV1 /
    // denyTimeAdjustmentRequestV1) which use the Admin SDK and bypass these
    // rules. Direct client writes are denied across the board so an
    // employee cannot flip status to "approved" via a raw Firestore SDK
    // call, and an admin cannot accidentally mutate effective fields
    // outside the audited approval flow. Reads remain client-visible (own
    // for employees; any for admins) so the admin tab and employee UI keep
    // working.
    match /time_adjustment_requests/{requestId} {
      allow read: if isPioneerAdmin()
                  || (request.auth != null
                      && resource.data.employee_uid == request.auth.uid);
      allow create: if false;   // Cloud Function only — createTimeAdjustmentRequestV1
      allow update: if false;   // Cloud Function only — approveTimeAdjustmentRequestV1 / denyTimeAdjustmentRequestV1
      allow delete: if false;
    }

    // ====================================================================
    // Phase 1A — Office Manager Mission Control.
    // ====================================================================
    // Four append-leaning collections that store the Office Manager's
    // management-side observations + decisions. All admin-only because
    // these are management records, not operational data:
    //
    //   office_manager_reflections   — daily three-question reflection
    //                                  (what noticed / what concerns /
    //                                   what improve). One per manager
    //                                   per day; idempotent doc id =
    //                                   `<uid>__<YYYY-MM-DD>`.
    //   office_manager_bottlenecks   — "what decision are you waiting
    //                                  on?" single-choice poll. Doc id
    //                                  = `<uid>__<YYYY-MM-DD>`.
    //   office_manager_weekly_reviews — manual-entry hiring metrics for
    //                                  the week (Phase 1A) + future
    //                                  weekly aggregates. Doc id =
    //                                  ISO week tag e.g. "2026-W23".
    //   office_manager_improvements  — free-form improvement ideas
    //                                  (separate channel from the
    //                                  weekly reflection). Auto-id.
    //
    // Updates are admin-only. Deletes denied across the board so the
    // management record stays auditable. Cloud Functions (Admin SDK)
    // bypass these rules entirely for future automated aggregation.
    match /office_manager_reflections/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    match /office_manager_bottlenecks/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    match /office_manager_weekly_reviews/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    match /office_manager_improvements/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // ====================================================================
    // Phase 2A.1 — Hiring funnel intelligence foundation.
    // ====================================================================
    // Two collections that will hold synced GHL (or manually-imported)
    // hiring funnel data. Phase 2A.1 ships the schema + admin rules
    // only — no writer yet. Phase 2A.2 will add syncGhlHiringV1.
    //
    //   office_manager_hiring_snapshots — one doc per snapshot date
    //                                     (typically YYYY-MM-DD). Holds
    //                                     rollup counts for a period.
    //                                     The manager dashboard reads
    //                                     the most recent snapshot for
    //                                     the current week + last 30 d.
    //
    //   office_manager_hiring_events    — append-only candidate-level
    //                                     event log from GHL webhooks
    //                                     (Phase 2A.3 if needed). Phase
    //                                     2A.1 declares the rules so
    //                                     ingestion can begin later
    //                                     without a rule deploy.
    //
    // Both collections are admin-only CRUD, no deletes — same shape as
    // every other office_manager_* collection.
    match /office_manager_hiring_snapshots/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }
    match /office_manager_hiring_events/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isPioneerAdmin();
      allow update: if isPioneerAdmin();
      allow delete: if false;
    }

    // ====================================================================
    // Employee action events — lightweight client-side click log.
    // ====================================================================
    // Phase A of the Deputy clock-in launcher work. Every "Open Deputy"
    // tap on the staff surfaces (Today's Work assignment card, clock-in
    // reminder banner, DCR-submit success page) writes one doc here so
    // ops can troubleshoot "I tapped Open Deputy but didn't get to the
    // app" reports.
    //
    // Schema (validated by rules):
    //   action      string                — "open_deputy" today; namespaced for future use
    //   source      string                — surface identifier (today_work_card / clock_in_reminder / dcr_success)
    //   staff       map { uid, email, displayName? }
    //   staff.uid   string                — must equal request.auth.uid
    //   created_at  serverTimestamp       — set client-side via FieldValue
    //   Optional:   shift_id, sync_date, user_agent, page_url
    //
    // Read: admin-only. Update / delete: forbidden — this is an append-only
    // audit log; mistakes get superseded by new events, never edited.
    match /employee_action_events/{id} {
      allow read:   if isPioneerAdmin();
      allow create: if isActiveStaff()
                    && request.resource.data.action is string
                    && request.resource.data.source is string
                    && request.resource.data.staff is map
                    && request.resource.data.staff.uid is string
                    && request.resource.data.staff.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Default-deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
